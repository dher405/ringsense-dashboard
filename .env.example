# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Encryption ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_TO_A_64_CHAR_HEX_STRING

# ─── Session Secret ──────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# ─── Admin Password (for the settings page) ─────────────────────────────────
# This protects the configuration UI. Set a strong password.
ADMIN_PASSWORD=changeme
