# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Encryption ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_TO_A_64_CHAR_HEX_STRING

# ─── Session Secret ──────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# ─── Admin Password (fallback for initial setup before users are created) ────
ADMIN_PASSWORD=changeme

# ─── Azure AD SSO (optional — configure in Settings UI instead) ──────────────
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
