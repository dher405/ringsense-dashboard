{
  "name": "ringsense-dashboard",
  "version": "2.0.0",
  "private": true,
  "description": "RingSense Call Insights Dashboard with secure backend, encrypted credential storage, and scheduled SFTP uploads",
  "scripts": {
    "start": "node server/index.js",
    "dev:server": "node server/index.js",
    "dev:client": "react-scripts start",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "react-scripts build",
    "heroku-postbuild": "npm run build",
    "render-build": "npm run build"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "ssh2-sftp-client": "^10.0.3",
    "uuid": "^9.0.0",
    "pdfkit": "^0.15.2"
  },
  "proxy": "http://localhost:4000",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}